<?xml version="1.0" encoding="utf-8"?>
<!--
  Tadabbur home screen widget (4x2). Layout mirrors the app's quiet,
  identity-driven aesthetic: warm cream card, Arabic-first hierarchy,
  verse reference as footer pill. No icons competing with the text —
  the ayah IS the icon.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_header"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/widget_header"
            android:textColor="@color/widget_primary"
            android:textSize="9sp"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_secondary"
            android:textSize="9sp"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_arabic"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/widget_text_primary"
        android:textSize="14sp"
        android:textDirection="rtl"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3"
        android:text="@string/widget_placeholder_arabic" />

    <TextView
        android:id="@+id/widget_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:textColor="@color/widget_text_secondary"
        android:textSize="10sp"
        android:textStyle="italic"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="@string/widget_placeholder_translation" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:background="@drawable/widget_pill"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView
            android:id="@+id/widget_verse_ref"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/widget_text_secondary"
            android:textSize="9sp"
            android:letterSpacing="0.05"
            android:textStyle="bold"
            android:text="Tadabbur" />
    </LinearLayout>
</LinearLayout>
