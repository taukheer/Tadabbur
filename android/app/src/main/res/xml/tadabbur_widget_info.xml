<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget metadata for the Tadabbur home screen widget.
  The minWidth/minHeight follow the standard 4 col × 2 row layout
  (4 × 70 − 30 = 250dp wide, 2 × 70 − 30 = 110dp tall).
  Resizable horizontal + vertical so users on small phones can make
  it smaller and tablet users can expand it.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:minResizeWidth="180dp"
    android:minResizeHeight="110dp"
    android:updatePeriodMillis="86400000"
    android:initialLayout="@layout/tadabbur_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@mipmap/ic_launcher"
    android:description="@string/widget_description" />
